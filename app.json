{
  "expo": {
    "name": "wafflelog-v2",
    "slug": "wafflelog-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wafflelogv2",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wafflelog.wafflelogv2"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.wafflelog.wafflelogv2",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#F7CF46",
          "dark": {
            "backgroundColor": "#F7CF46"
          }
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-sqlite",
      "expo-document-picker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Wafflelog uses your photo library so you can attach trip images to pins.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6da4a283-28db-422d-9518-6a89b5ea677a"
      }
    },
    "owner": "wafflelog"
  }
}
