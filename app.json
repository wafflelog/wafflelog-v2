{
  "expo": {
    "name": "wafflelog-v2",
    "slug": "wafflelog-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wafflelogv2",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wafflelog.wafflelogv2"
    },
    "android": {
      // "adaptiveIcon": {
      //   "backgroundColor": "#E6F4FE",
      //   "foregroundImage": "./assets/images/android-icon-foreground.png",
      //   "backgroundImage": "./assets/images/android-icon-background.png",
      //   "monochromeImage": "./assets/images/android-icon-monochrome.png"
      // },
      "predictiveBackGestureEnabled": false,
      "package": "com.wafflelog.wafflelogv2"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7CF46",
          "dark": {
            "backgroundColor": "#F7CF46"
          }
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-sqlite",
      "expo-document-picker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Wafflelog uses your photo library so you can attach trip images to pins.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
